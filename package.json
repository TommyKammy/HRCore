{
  "name": "hrcore",
  "version": "0.0.0",
  "description": "Open-source HR core system for identity-driven employee lifecycle management.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "dev": "tsx src/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  }
}
