{
  "name": "hrcore",
  "version": "0.0.0",
  "description": "Open-source HR core system for identity-driven employee lifecycle management.",
  "type": "module",
  "private": true,
  "scripts": {
    "audit": "npm audit --audit-level=moderate",
    "build": "tsc -p tsconfig.json",
    "db:check": "drizzle-kit check --config=drizzle.config.ts",
    "dev": "tsx src/server.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "policy:mvp-a": "tsx src/mvp-a-policy-as-code-ci.ts",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "verify:pre-pr": "npm run build && npm run policy:mvp-a && npm test && npm run format:check && npm run audit && npm run db:check"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "drizzle-kit": "0.31.10",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "drizzle-kit": {
      "esbuild": "0.28.1"
    },
    "@esbuild-kit/core-utils": {
      ".": "3.3.2",
      "esbuild": "0.28.1"
    },
    "tsx": {
      "esbuild": "0.28.1"
    }
  }
}
