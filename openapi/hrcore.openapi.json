{
  "openapi": "3.1.0",
  "info": {
    "title": "HRCore API",
    "version": "0.0.0",
    "description": "Initial OpenAPI-first contract seed for HRCore."
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Return application health",
        "responses": {
          "200": {
            "description": "The application is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "const": "ok"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
