{
  "openapi": "3.1.0",
  "info": {
    "title": "HRCore API",
    "version": "0.0.0",
    "description": "Initial OpenAPI-first contract seed for HRCore."
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Return application health",
        "responses": {
          "200": {
            "description": "The application is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/provisioning-runs": {
      "get": {
        "operationId": "listProvisioningRuns",
        "summary": "List synthetic provisioning run evidence",
        "description": "Returns the PoC-depth synthetic Okta mastering run evidence needed for operator inspection. This is not a raw payload viewer, CSV export surface, production audit archive, or WORM log.",
        "responses": {
          "200": {
            "description": "Synthetic provisioning run evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvisioningRunEvidenceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/audit/mvp-a/onboarding-correlations/{correlationId}": {
      "get": {
        "operationId": "getMvpAOnboardingCorrelationAuditTrace",
        "summary": "Inspect bounded MVP-A onboarding audit evidence by correlation ID",
        "description": "Returns the repo-owned MVP-A onboarding correlation trace summary for one explicit correlation ID after runtime actor, tenant/environment, field-scope, and data-scope checks plus request-owner binding. Requested scope headers and request-owner binding are validated before the full trace verifier returns correlation-specific evidence. Trace summary fields are filtered to the authorized evidence surfaces and field scopes. This bounded surface fails closed when required linked evidence is missing and omits later-wave disclosure, archive, provider-search, and production field-permission behavior.",
        "parameters": [
          {
            "name": "correlationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "x-hrcore-mvp-a-actor-id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          },
          {
            "name": "x-hrcore-mvp-a-tenant-environment",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "const": "repo_owned_synthetic_mvp_a_onboarding"
            }
          },
          {
            "name": "x-hrcore-mvp-a-evidence-surfaces",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-hrcore-mvp-a-field-scopes",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Bounded MVP-A onboarding correlation trace evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MvpAOnboardingCorrelationTraceResponse"
                }
              }
            }
          },
          "403": {
            "description": "Runtime actor, tenant/environment, field-scope, or data-scope authorization failed closed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Required linked onboarding audit evidence was missing or inconsistent.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The local MVP-A onboarding audit trace database was not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/onboarding/new-hire": {
      "get": {
        "operationId": "renderMvpAOnboardingWizard",
        "summary": "Render MVP-A new hire onboarding wizard",
        "description": "Returns the MVP-A-only new hire wizard surface for draft, validation, and submit. Later-wave privacy, provider, and production control surfaces remain outside this operation.",
        "responses": {
          "200": {
            "description": "MVP-A onboarding wizard HTML.",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/onboarding/new-hire/transaction-requests/validate": {
      "post": {
        "operationId": "validateMvpAOnboardingTransactionRequest",
        "summary": "Validate an MVP-A onboarding transaction request",
        "description": "Validates the submitted body through the transaction_request contract without applying business rules in the UI layer.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingTransactionRequestInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The request is valid for the MVP-A onboarding contract.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnboardingTransactionRequestValidationResult"
                }
              }
            }
          },
          "400": {
            "description": "The request violated the MVP-A onboarding transaction_request contract.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/onboarding/new-hire/transaction-requests": {
      "post": {
        "operationId": "saveMvpAOnboardingTransactionRequest",
        "summary": "Save or submit an MVP-A onboarding transaction request",
        "description": "Creates, edits draft, or submits an MVP-A onboarding transaction_request. Draft edits are accepted only for the same explicit request, person, and correlation binding.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingTransactionRequestInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "An existing draft request was edited.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnboardingTransactionRequestPersistenceResult"
                }
              }
            }
          },
          "201": {
            "description": "A new draft was created, a request was submitted, or an idempotent submit was accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnboardingTransactionRequestPersistenceResult"
                }
              }
            }
          },
          "400": {
            "description": "The request was malformed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The request conflicts with an existing authoritative transaction_request binding.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The local onboarding transaction_request database was not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/onboarding/new-hire/transaction-requests/{transactionRequestId}/decisions": {
      "post": {
        "operationId": "decideMvpAOnboardingTransactionRequest",
        "summary": "Record an MVP-A onboarding approval decision",
        "description": "Applies the MVP-A onboarding approval state machine for approve, return, reject, and cancel decisions. This records local audit evidence only; production RBAC, self-approval prevention, break-glass, two-key controls, and advanced delegation remain outside this child.",
        "parameters": [
          {
            "name": "transactionRequestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OnboardingApprovalDecisionInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The approval decision was applied or an idempotent retry was recognized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OnboardingApprovalDecisionResult"
                }
              }
            }
          },
          "400": {
            "description": "The decision command was malformed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "The onboarding transaction request decision target was not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The decision is illegal for the current authoritative transaction_request state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The local onboarding transaction_request database was not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/onboarding/new-hire/transaction-requests/{transactionRequestId}/apply": {
      "post": {
        "operationId": "applyMvpAOnboardingTransactionRequest",
        "summary": "Apply an approved MVP-A onboarding transaction request",
        "description": "Commits the approved onboarding request into local HR Core person, employment, assignment, lifecycle, and audit evidence. Okta projection, provider writeback, later transfer, termination, leave, and regulated-data behavior remain outside this operation.",
        "parameters": [
          {
            "name": "transactionRequestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApplyApprovedOnboardingTransactionRequestInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The approved onboarding request was applied or an idempotent completed retry was recognized.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppliedOnboardingTransactionRequestResult"
                }
              }
            }
          },
          "400": {
            "description": "The apply command was malformed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "The request is not approved or the completed apply evidence conflicts with the retry command.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "The local onboarding transaction_request database was not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/writeback-events/work-email": {
      "post": {
        "operationId": "ingestSyntheticWorkEmailWriteback",
        "summary": "Ingest synthetic work email writeback evidence",
        "description": "Accepts local-only synthetic provider-confirmed work email writeback events. This is not a production webhook, signature verification surface, real Okta call, approval workflow, or audit immutability claim.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyntheticWorkEmailWritebackInput"
              }
            }
          }
        },
        "responses": {
          "400": {
            "description": "Synthetic writeback input was malformed or violated local synthetic constraints.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "201": {
            "description": "Synthetic writeback event was persisted and either applied or recorded as PoC conflict evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyntheticWorkEmailWritebackResult"
                }
              }
            }
          },
          "503": {
            "description": "The local writeback ingest database was not configured."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "const": "ok"
          }
        },
        "additionalProperties": false
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ProvisioningRunEvidenceResponse": {
        "type": "object",
        "required": ["runs"],
        "properties": {
          "runs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProvisioningRunEvidence"
            }
          }
        },
        "additionalProperties": false
      },
      "ProvisioningRunEvidence": {
        "type": "object",
        "required": [
          "runId",
          "status",
          "targetOperation",
          "result",
          "correlationId",
          "synthetic"
        ],
        "properties": {
          "runId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "needs_attention"]
          },
          "targetOperation": {
            "type": "string",
            "enum": ["create", "update", "disable", "replace_user_groups"]
          },
          "result": {
            "type": "string",
            "enum": [
              "success",
              "skipped",
              "retryable_failure",
              "permanent_failure"
            ]
          },
          "correlationId": {
            "type": "string"
          },
          "synthetic": {
            "type": "boolean",
            "const": true
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingCorrelationTraceResponse": {
        "type": "object",
        "required": [
          "correlationId",
          "evidenceType",
          "authorization",
          "trace",
          "deferredProductionGates"
        ],
        "properties": {
          "correlationId": {
            "type": "string"
          },
          "evidenceType": {
            "type": "string",
            "const": "mvp_a_onboarding_correlation_trace"
          },
          "authorization": {
            "$ref": "#/components/schemas/MvpAOnboardingRuntimeAuthorizationDecision"
          },
          "trace": {
            "$ref": "#/components/schemas/MvpAOnboardingCorrelationTraceSummary"
          },
          "deferredProductionGates": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingRuntimeAuthorizationDecision": {
        "type": "object",
        "required": [
          "decision",
          "gateId",
          "actorId",
          "tenantEnvironmentId",
          "evidenceSurfaces",
          "fieldScopes",
          "dataScopes",
          "auditCorrelation"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "const": "allow"
          },
          "gateId": {
            "type": "string",
            "const": "mvp_a_onboarding_evidence_authorization_v1"
          },
          "actorId": {
            "type": "string"
          },
          "tenantEnvironmentId": {
            "type": "string",
            "const": "repo_owned_synthetic_mvp_a_onboarding"
          },
          "evidenceSurfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fieldScopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dataScopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "auditCorrelation": {
            "type": "string",
            "const": "same_onboarding_request_or_linked_operation"
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingCorrelationTraceSummary": {
        "type": "object",
        "properties": {
          "transactionRequest": {
            "$ref": "#/components/schemas/MvpAOnboardingTransactionTrace"
          },
          "person": {
            "$ref": "#/components/schemas/MvpAOnboardingPersonTrace"
          },
          "employment": {
            "$ref": "#/components/schemas/MvpAOnboardingEmploymentTrace"
          },
          "assignment": {
            "$ref": "#/components/schemas/MvpAOnboardingAssignmentTrace"
          },
          "approvalAuditEvent": {
            "$ref": "#/components/schemas/MvpAOnboardingAuditEventTrace"
          },
          "applyAuditEvent": {
            "$ref": "#/components/schemas/MvpAOnboardingAuditEventTrace"
          },
          "auditEventCount": {
            "type": "integer",
            "minimum": 0
          },
          "lifecycleEventId": {
            "type": ["string", "null"]
          },
          "applyJobAttemptCount": {
            "type": "integer",
            "minimum": 0
          },
          "workEmailWritebackEventId": {
            "type": ["string", "null"]
          },
          "providerRefreshId": {
            "type": ["string", "null"]
          },
          "workEmailConflictId": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingTransactionTrace": {
        "type": "object",
        "required": ["id", "requestType", "statusCode", "correlationId"],
        "properties": {
          "id": {
            "type": "string"
          },
          "requestType": {
            "type": "string",
            "const": "hire"
          },
          "statusCode": {
            "type": "string",
            "const": "completed"
          },
          "correlationId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingPersonTrace": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingEmploymentTrace": {
        "type": "object",
        "required": [
          "id",
          "employmentCode",
          "statusCode",
          "startDate",
          "endDate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "employmentCode": {
            "type": "string"
          },
          "statusCode": {
            "type": "string",
            "enum": ["active", "inactive", "terminated"]
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingAssignmentTrace": {
        "type": "object",
        "required": [
          "id",
          "employmentId",
          "assignmentCode",
          "organizationCode",
          "positionCode",
          "startDate",
          "endDate"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "employmentId": {
            "type": "string"
          },
          "assignmentCode": {
            "type": "string"
          },
          "organizationCode": {
            "type": "string"
          },
          "positionCode": {
            "type": ["string", "null"]
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      },
      "MvpAOnboardingAuditEventTrace": {
        "type": "object",
        "required": [
          "id",
          "actorId",
          "action",
          "subjectTable",
          "subjectId",
          "occurredAt",
          "correlationId"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "actorId": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": ["mvp_a.onboarding.approve", "mvp_a.onboarding.apply"]
          },
          "subjectTable": {
            "type": "string",
            "enum": ["transaction_request", "lifecycle_event"]
          },
          "subjectId": {
            "type": "string"
          },
          "occurredAt": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ValidationErrorResponse": {
        "type": "object",
        "required": ["error", "validationErrors"],
        "properties": {
          "error": {
            "type": "string"
          },
          "validationErrors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationErrorDetail"
            }
          }
        },
        "additionalProperties": false
      },
      "ValidationErrorDetail": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "OnboardingTransactionRequestValidationResult": {
        "type": "object",
        "required": ["valid", "requestType", "statusCode", "payloadVersion"],
        "properties": {
          "valid": {
            "type": "boolean",
            "const": true
          },
          "requestType": {
            "type": "string",
            "const": "hire"
          },
          "statusCode": {
            "type": "string",
            "enum": ["draft", "submitted"]
          },
          "payloadVersion": {
            "type": "string",
            "const": "mvp_a_onboarding_v1"
          }
        },
        "additionalProperties": false
      },
      "OnboardingTransactionRequestPersistenceResult": {
        "type": "object",
        "required": [
          "personId",
          "transactionRequestId",
          "statusCode",
          "correlationId"
        ],
        "properties": {
          "personId": {
            "type": "string"
          },
          "transactionRequestId": {
            "type": "string"
          },
          "statusCode": {
            "type": "string",
            "enum": [
              "draft",
              "submitted",
              "returned",
              "rejected",
              "cancelled",
              "approved",
              "completed"
            ]
          },
          "correlationId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "OnboardingApprovalDecisionInput": {
        "type": "object",
        "required": ["decision", "decidedAt", "decidedBy", "correlationId"],
        "properties": {
          "decision": {
            "type": "string",
            "enum": ["approve", "return", "reject", "cancel"]
          },
          "decidedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}T(?:[01]\\d|2[0-3]):[0-5]\\d:[0-5]\\d(?:\\.\\d+)?(?:Z|[+-](?:[01]\\d|2[0-3]):[0-5]\\d)$"
          },
          "decidedBy": {
            "type": "string",
            "minLength": 1
          },
          "correlationId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "OnboardingApprovalDecisionResult": {
        "type": "object",
        "required": [
          "personId",
          "transactionRequestId",
          "statusCode",
          "decision",
          "auditEventId",
          "correlationId"
        ],
        "properties": {
          "personId": {
            "type": "string"
          },
          "transactionRequestId": {
            "type": "string"
          },
          "statusCode": {
            "type": "string",
            "enum": ["returned", "rejected", "cancelled", "approved"]
          },
          "decision": {
            "type": "string",
            "enum": ["approve", "return", "reject", "cancel"]
          },
          "auditEventId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ApplyApprovedOnboardingTransactionRequestInput": {
        "type": "object",
        "required": ["appliedAt", "appliedBy", "correlationId"],
        "properties": {
          "appliedAt": {
            "type": "string",
