{
  "openapi": "3.1.0",
  "info": {
    "title": "HRCore API",
    "version": "0.0.0",
    "description": "Initial OpenAPI-first contract seed for HRCore."
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Return application health",
        "responses": {
          "200": {
            "description": "The application is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/provisioning-runs": {
      "get": {
        "operationId": "listProvisioningRuns",
        "summary": "List synthetic provisioning run evidence",
        "description": "Returns the PoC-depth synthetic Okta mastering run evidence needed for operator inspection. This is not a raw payload viewer, CSV export surface, production audit archive, or WORM log.",
        "responses": {
          "200": {
            "description": "Synthetic provisioning run evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvisioningRunEvidenceResponse"
                }
              }
            }
          }
        }
      }
    },
    "/writeback-events/work-email": {
      "post": {
        "operationId": "ingestSyntheticWorkEmailWriteback",
        "summary": "Ingest synthetic work email writeback evidence",
        "description": "Accepts local-only synthetic provider-confirmed work email writeback events. This is not a production webhook, signature verification surface, real Okta call, approval workflow, or audit immutability claim.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyntheticWorkEmailWritebackInput"
              }
            }
          }
        },
        "responses": {
          "400": {
            "description": "Synthetic writeback input was malformed or violated local synthetic constraints.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "201": {
            "description": "Synthetic writeback event was persisted and either applied or recorded as PoC conflict evidence.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyntheticWorkEmailWritebackResult"
                }
              }
            }
          },
          "503": {
            "description": "The local writeback ingest database was not configured."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "const": "ok"
          }
        },
        "additionalProperties": false
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ProvisioningRunEvidenceResponse": {
        "type": "object",
        "required": ["runs"],
        "properties": {
          "runs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProvisioningRunEvidence"
            }
          }
        },
        "additionalProperties": false
      },
      "ProvisioningRunEvidence": {
        "type": "object",
        "required": [
          "runId",
          "status",
          "targetOperation",
          "result",
          "correlationId",
          "synthetic"
        ],
        "properties": {
          "runId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "needs_attention"]
          },
          "targetOperation": {
            "type": "string",
            "enum": ["create", "update", "disable", "replace_user_groups"]
          },
          "result": {
            "type": "string",
            "enum": [
              "success",
              "skipped",
              "retryable_failure",
              "permanent_failure"
            ]
          },
          "correlationId": {
            "type": "string"
          },
          "synthetic": {
            "type": "boolean",
            "const": true
          }
        },
        "additionalProperties": false
      },
      "SyntheticWorkEmailWritebackInput": {
        "type": "object",
        "required": [
          "eventId",
          "personId",
          "contactPointId",
          "providerName",
          "providerSubjectId",
          "providerValue",
          "targetContactType",
          "correlationId",
          "receivedAt",
          "pocMarker"
        ],
        "properties": {
          "eventId": {
            "type": "string"
          },
          "personId": {
            "type": "string"
          },
          "contactPointId": {
            "type": "string"
          },
          "providerName": {
            "type": "string",
            "const": "synthetic_okta"
          },
          "providerSubjectId": {
            "type": "string"
          },
          "providerValue": {
            "type": "string"
          },
          "targetContactType": {
            "type": "string",
            "const": "work_email"
          },
          "correlationId": {
            "type": "string"
          },
          "receivedAt": {
            "type": "string"
          },
          "pocMarker": {
            "type": "string",
            "const": "synthetic_poc"
          }
        },
        "additionalProperties": false
      },
      "SyntheticWorkEmailWritebackResult": {
        "type": "object",
        "required": [
          "eventId",
          "personId",
          "contactPointId",
          "providerName",
          "providerSubjectId",
          "correlationId",
          "applied"
        ],
        "properties": {
          "eventId": {
            "type": "string"
          },
          "personId": {
            "type": "string"
          },
          "contactPointId": {
            "type": "string"
          },
          "providerName": {
            "type": "string",
            "const": "synthetic_okta"
          },
          "providerSubjectId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "applied": {
            "type": "boolean"
          },
          "conflict": {
            "$ref": "#/components/schemas/SyntheticWorkEmailConflictEvidence"
          }
        },
        "additionalProperties": false
      },
      "SyntheticWorkEmailConflictEvidence": {
        "type": "object",
        "required": [
          "conflictId",
          "conflictType",
          "currentContactValue",
          "attemptedProviderValue",
          "correlationId"
        ],
        "properties": {
          "conflictId": {
            "type": "string"
          },
          "conflictType": {
            "type": "string",
            "enum": ["inbound_value_conflict", "provider_refresh_conflict"]
          },
          "currentContactValue": {
            "type": "string"
          },
          "attemptedProviderValue": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
